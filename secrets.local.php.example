<?php
/**
 * On the server: copy to secrets.local.php in the site root (next to index.php).
 * Loaded by lib/env.php (bootstrap, Maps-only pages, etc.). Gitignored; blocked by root .htaccess.
 *
 * Put AWS keys, Google Maps API key, and any other local secrets here — not in git.
 *
 * Set both putenv() and $_ENV: on some PHP-FPM hosts getenv() does not see putenv() alone,
 * which would make the AWS SDK fall through to the EC2 metadata service and time out.
 */
$key = 'YOUR_ACCESS_KEY_ID';
$secret = 'YOUR_SECRET_ACCESS_KEY';
$region = 'us-east-1';

putenv('AWS_ACCESS_KEY_ID=' . $key);
putenv('AWS_SECRET_ACCESS_KEY=' . $secret);
putenv('AWS_DEFAULT_REGION=' . $region);
$_ENV['AWS_ACCESS_KEY_ID'] = $key;
$_ENV['AWS_SECRET_ACCESS_KEY'] = $secret;
$_ENV['AWS_DEFAULT_REGION'] = $region;

// Optional: Google Maps JavaScript API (browser key). Do not commit real keys to git.
$googleMapsKey = 'YOUR_GOOGLE_MAPS_BROWSER_KEY';
putenv('GOOGLE_MAPS_API_KEY=' . $googleMapsKey);
$_ENV['GOOGLE_MAPS_API_KEY'] = $googleMapsKey;
